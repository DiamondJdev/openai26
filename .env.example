# ClaimLens local demo configuration. Copy to .env.local and fill in.

# OpenAI Responses API — required to run a live investigation.
OPENAI_API_KEY=
# Model id for the investigation agent (vision + tool calling).
CLAIMLENS_MODEL=gpt-5.6

# Base URL used when generating the customer's private claim link (for copy/share).
CLAIMLENS_PUBLIC_BASE_URL=http://localhost:3000

# Required server-only deployment configuration. The Basic Auth gate matches
# exactly /employee; these variables are not exposed to the browser.
EMPLOYEE_USERNAME=
EMPLOYEE_PASSWORD=
DATABASE_URL=

# Configure Blob with this token locally, or with the OIDC/store pair on Vercel.
BLOB_READ_WRITE_TOKEN=
VERCEL_OIDC_TOKEN=
BLOB_STORE_ID=

# Path to the seeded footage manifest + visit index (JSON).
CLAIMLENS_MANIFEST_PATH=fixtures/manifest.json

# Investigation guardrail.
CLAIMLENS_MAX_INVESTIGATION_MS=45000
