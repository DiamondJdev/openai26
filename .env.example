# ClaimLens local demo configuration. Copy to .env.local and fill in.

# OpenAI Responses API — required to run a live investigation.
OPENAI_API_KEY=
# Model id for the investigation agent (vision + tool calling).
CLAIMLENS_MODEL=gpt-5.6

# Base URL used when generating the customer's private claim link (for copy/share).
CLAIMLENS_PUBLIC_BASE_URL=http://localhost:3000

# Required server-only employee-console credentials. Signed sessions protect all
# employee pages and APIs (except login/logout); these values stay server-only.
EMPLOYEE_USERNAME=
EMPLOYEE_PASSWORD=
DATABASE_URL=

# Local commands use this private Blob token. Keep it out of Vercel deployment
# variables when using the OIDC/store configuration below.
BLOB_READ_WRITE_TOKEN=
# On Vercel, enable OIDC and set the private Blob store ID. Vercel supplies the
# OIDC token at runtime; never put a real token in this file.
VERCEL_OIDC_TOKEN=
BLOB_STORE_ID=

# Path to the seeded footage manifest + visit index (JSON).
CLAIMLENS_MANIFEST_PATH=fixtures/manifest.json

# Investigation guardrail.
CLAIMLENS_MAX_INVESTIGATION_MS=45000
