# ClaimLens local demo configuration. Copy to .env.local and fill in.

# OpenAI Responses API — required to run a live investigation.
OPENAI_API_KEY=
# Model id for the investigation agent (vision + tool calling).
CLAIMLENS_MODEL=gpt-5.6

# Base URL used when generating the customer's private claim link (for copy/share).
CLAIMLENS_PUBLIC_BASE_URL=http://localhost:3000

# Optional. When set, the /employee console + /api/employee/* require HTTP Basic
# auth (any username, password = this token). Leave empty for trusted local use;
# SET IT before tunneling the app (e.g. ngrok), since exposing the customer link
# also exposes the employee routes. Generate with: openssl rand -hex 24
EMPLOYEE_ACCESS_TOKEN=

# Local data roots (purged on startup/reset). Relative to project root.
CLAIMLENS_DATA_DIR=.data
CLAIMLENS_DB_PATH=.data/claimlens.sqlite

# Path to the seeded footage manifest + visit index (JSON).
CLAIMLENS_MANIFEST_PATH=fixtures/manifest.json

# Investigation guardrails.
CLAIMLENS_MAX_TOOL_CALLS=12
CLAIMLENS_MAX_INVESTIGATION_MS=45000
